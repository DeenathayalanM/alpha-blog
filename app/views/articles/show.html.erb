<h1 class="text-center p-4"> Show article</h1>
<div class="container ">
  <div class="row justify-content-md-center mt-4 ">
    <div class="col-8">
      <div class="card text-center shadow mb-5 bg-white rounded">
        <div class="card-header bg-warning ">
          By <%= @article.user.name %>
        </div>
        <div class="card-body">
          <h5 class="card-title text-success"><%= @article.title%></h5>
          <p class="card-text"><%= @article.desc%></p>
          <%= link_to 'Edit', edit_article_path(@article) , class: "btn btn-primary"%>
          <%= link_to 'Delete', article_path(@article), data: {turbo_method: :delete, turbo_confirm: "Are you sure want to delete?"}, class: "btn btn-primary"%>
        </div>
        <div class="card-footer text-body-secondary">
          <small> Created <%= time_ago_in_words(@article.created_at) %> ago ,Edited <%= time_ago_in_words(@article.updated_at) %> ago </small>
        </div>
      </div>
    </div>
  </div>
  <div>

    <div class="text-center">
      <%= link_to '[Back to article home page]' , articles_path %>
    </div>